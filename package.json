{
  "name": "on_the_money.js",
  "version": "0.1.1",
  "description": "An opinionated web project anti-framework enforcing deterministic, DOM-first architecture.",
  "type": "module",
  "main": "src/core/index.js",
  "bin": {
    "otm-lint": "./src/linter/main.js"
  },
  "scripts": {
    "test": "node --test test/**/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-lines=95 --test-coverage-branches=90 --test-coverage-functions=100 test/**/*.test.js",
    "check": "npm run test && npm run test:coverage",
    "lint": "node src/linter/main.js --check ./src"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "espree": "^10.0.0",
    "parse5": "^7.0.0",
    "css-tree": "^3.0.0"
  },
  "license": "MIT"
}
