{
	"name": "on_the_money",
	"version": "0.1.1",
	"description": "Opinionated, attribute-driven, standards-oriented modern framework. <2KB gzip. Native browser APIs only.",
	"type": "module",
	"main": "src/core/index.js",
	"module": "dist/on_the_money.min.js",
	"bin": {
		"otm-lint": "./src/linter/main.js"
	},
	"exports": {
		".": "./src/core/index.js",
		"./dist": "./dist/on_the_money.min.js"
	},
	"scripts": {
		"build": "esbuild src/core/index.js --bundle --minify --format=esm --outfile=dist/on_the_money.min.js",
		"test": "node --test test/*.test.js",
		"test:coverage": "node --test --experimental-test-coverage --test-coverage-lines=50 --test-coverage-branches=50 --test-coverage-functions=50 test/*.test.js",
		"check": "npm run lint && npm run build && npm run test && npm run test:coverage",
		"lint": "biome check ./src ./test ./examples",
		"lint:fix": "biome check --write ./src ./test ./examples",
		"otm": "node src/linter/main.js --check"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"css-tree": "3.1.0",
		"esbuild": "0.25.0",
		"espree": "10.3.0",
		"linkedom": "0.18.6",
		"parse5": "7.2.1"
	},
	"license": "MIT"
}
